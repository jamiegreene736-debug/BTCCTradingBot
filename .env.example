# Bitunix Futures OpenAPI keys — create at
# Profile → API Management → Futures OpenAPI on https://www.bitunix.com
# Enable "Read" + "Trade" permissions. The secret is shown only once.
BITUNIX_API_KEY=your_api_key
BITUNIX_SECRET_KEY=your_secret_key

# Dashboard password (HTTP Basic, username "admin").
# If unset/empty, the dashboard returns 503 — never serves data unauthed.
DASHBOARD_PASSWORD=pick_a_long_random_string

# scripts/ask_reviewers.py — push state exports to Grok / ChatGPT for review.
# Same value as DASHBOARD_PASSWORD (the script reads it as BOT_DASHBOARD_PASSWORD).
BOT_DASHBOARD_PASSWORD=same_as_DASHBOARD_PASSWORD
# Optional overrides:
#   BOT_BASE_URL              default https://btcc-trading-bot-production.up.railway.app
#   BOT_DASHBOARD_USER        default admin
# Reviewer API keys (only the providers you want to use are required):
XAI_API_KEY=your_xai_key_here          # https://console.x.ai
OPENAI_API_KEY=your_openai_key_here    # https://platform.openai.com/api-keys
# Optional model overrides:
#   XAI_MODEL                 default grok-4-latest
#   OPENAI_MODEL              default gpt-5
